<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.BingeWatch" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_color</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/surface_dark</item>

        <item name="android:statusBarColor" tools:targetApi="l">@color/bg_dark</item>

        <item name="textInputStyle">@style/Widget.App.TextInputLayout</item>
    </style>

    <style name="Widget.App.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/accent_color</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">@color/accent_color</item>
    </style>

    <style name="RoundedImageView">
        <item name="cornerSize">12dp</item>
    </style>

    <style name="CircleImageView">
        <item name="cornerSize">50%</item>
    </style>

    <style name="ShapeAppearance.MaterialComponents.LargeComponent" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerSize">50%</item>
    </style>
</resources>